# ---- Firebase Web (client) ----
# Used by public/assets/js/firebase-config.js
FIREBASE_API_KEY=your_firebase_web_api_key
FIREBASE_AUTH_DOMAIN=openframe-media.firebaseapp.com
FIREBASE_PROJECT_ID=openframe-media
FIREBASE_STORAGE_BUCKET=openframe-media.appspot.com
FIREBASE_MESSAGING_SENDER_ID=your_messaging_sender_id
FIREBASE_APP_ID=your_firebase_app_id

# ---- Firebase Admin SDK (server) ----
# When deployed to Cloud Functions these are not required (the runtime
# provides Application Default Credentials). Use the values below for
# local emulation or when running admin scripts outside Firebase.
GOOGLE_APPLICATION_CREDENTIALS=./service-account.json
FIREBASE_ADMIN_PROJECT_ID=openframe-media
FIREBASE_ADMIN_CLIENT_EMAIL=firebase-adminsdk@openframe-media.iam.gserviceaccount.com
FIREBASE_ADMIN_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nyour_private_key\n-----END PRIVATE KEY-----\n"

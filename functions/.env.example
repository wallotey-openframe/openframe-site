# ---- Recipient (where notifications go) ----
CONTACT_EMAIL=hello@openframe.media
CONTACT_PHONE=+233200000000

# ---- Nodemailer (SMTP) ----
SMTP_HOST=smtp.gmail.com
SMTP_PORT=465
SMTP_SECURE=true
SMTP_USER=notifications@openframe.media
SMTP_PASS=your_smtp_app_password
FROM_EMAIL=Open Frame Media <notifications@openframe.media>

# ---- Arkesel SMS ----
ARKESEL_API_KEY=your_arkesel_api_key
ARKESEL_SENDER_ID=OpenFrame

# ---- Admin bootstrap ----
ADMIN_BOOTSTRAP_KEY=change-this-to-a-long-random-secret
